{
  "name": "codecleaner",
  "displayName": "CodeCleaner",
  "description": "Code Cleaner by Siddarth Balaji",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.120.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "code-cleaner.run",
        "title": "Clean Code Engine"
      },
      {
        "command": "code-cleaner.cleanFolder",
        "title": "Clean Folder"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "code-cleaner.run",
          "group": "modification"
        }
      ],
      "explorer/context": [
        {
          "command": "code-cleaner.cleanFolder",
          "group": "modification",
          "when": "explorerResourceIsFolder"
        }
      ]
    },
    "configuration": {
      "title": "Code Cleaner",
      "properties": {
        "code-cleaner.removeEmojis": {
          "type": "boolean",
          "default": true,
          "description": "Remove emojis when cleaning code."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/vscode": "^1.120.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "typescript-eslint": "^8.56.1",
    "eslint": "^9.39.3",
    "typescript": "^5.9.3",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2"
  }
}