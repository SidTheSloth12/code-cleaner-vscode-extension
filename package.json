{
  "name": "code-cleaner-by-siddarthsbalaji",
  "displayName": "CodeCleaner",
  "description": "Minifies and cleans up code within the editor.",
  "version": "2.0.4",
  "publisher": "SiddarthSBalaji",
  "repository": {
    "type": "git",
    "url": "https://github.com/SidTheSloth12/code-cleaner-vscode-extension.git"
  },
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Formatters",
    "Other"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "configuration": {
      "title": "CodeCleaner",
      "properties": {
        "codeCleaner.removeComments": {
          "type": "boolean",
          "default": true,
          "description": "If enabled, comments will be removed when cleaning code."
        },
        "codeCleaner.removeBlankLines": {
          "type": "boolean",
          "default": true,
          "description": "If enabled, blank lines will be removed."
        },
        "codeCleaner.removeSpacesAroundOperators": {
          "type": "boolean",
          "default": true,
          "description": "If enabled, spaces around operators will be removed."
        },
        "codeCleaner.removeIndentation": {
          "type": "boolean",
          "default": true,
          "description": "If enabled, indentation will be removed."
        },
        "codeCleaner.cleanOnSave": {
          "type": "boolean",
          "default": false,
          "description": "If enabled, code will be automatically cleaned when the file is saved."
        }
      }
    },
    "commands": [
      {
        "command": "code-cleaner.cleanCode",
        "title": "Clean & Minify Code"
      },
      {
        "command": "code-cleaner.cleanAndCopy",
        "title": "CodeCleaner: Clean and Copy to Clipboard"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "code-cleaner.cleanCode",
          "group": "modification"
        },
        {
          "command": "code-cleaner.cleanAndCopy",
          "group": "modification"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src --ext ts"
  },
  "devDependencies": {
    "@types/emscripten": "^1.41.5",
    "@types/node": "18.x",
    "@types/vscode": "^1.80.0",
    "typescript": "^5.1.3"
  },
  "dependencies": {
    "tree-sitter-wasms": "^0.1.13",
    "web-tree-sitter": "^0.26.9"
  }
}