{
  "name": "code-cleaner-by-siddarthsbalaji",
  "displayName": "CodeCleaner",
  "description": "Minifies, cleans up, and refactors code within the editor.",
  "version": "3.0.2",
  "publisher": "SiddarthSBalaji",
  "repository": {
    "type": "git",
    "url": "https://github.com/SidTheSloth12/code-cleaner-vscode-extension.git"
  },
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Formatters",
    "Other"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "configuration": {
      "title": "CodeCleaner",
      "properties": {
        "codeCleaner.profile": {
          "type": "string",
          "enum": [
            "Format",
            "Minify",
            "Obfuscate"
          ],
          "default": "Minify",
          "description": "Profile to use when cleaning code. 'Format' standardizes spacing. 'Minify' aggressively removes whitespace. 'Obfuscate' mangles JS/TS variables."
        },
        "codeCleaner.aiProvider": {
          "type": "string",
          "enum": [
            "Gemini",
            "OpenAI"
          ],
          "default": "Gemini",
          "description": "The AI provider to use for the AI Clean & Refactor feature."
        },
        "codeCleaner.apiKey": {
          "type": "string",
          "default": "",
          "description": "Your API key for the selected AI provider."
        },
        "codeCleaner.removeComments": {
          "type": "boolean",
          "default": true,
          "description": "If enabled, comments will be removed when cleaning code."
        },
        "codeCleaner.removeBlankLines": {
          "type": "boolean",
          "default": true,
          "description": "If enabled, blank lines will be removed."
        },
        "codeCleaner.removeSpacesAroundOperators": {
          "type": "boolean",
          "default": true,
          "description": "If enabled, spaces around operators will be removed."
        },
        "codeCleaner.removeIndentation": {
          "type": "boolean",
          "default": true,
          "description": "If enabled, indentation will be removed."
        },
        "codeCleaner.cleanOnSave": {
          "type": "boolean",
          "default": false,
          "description": "If enabled, code will be automatically cleaned when the file is saved."
        }
      }
    },
    "commands": [
      {
        "command": "code-cleaner.cleanCode",
        "title": "CodeCleaner: Clean"
      },
      {
        "command": "code-cleaner.cleanAndCopy",
        "title": "CodeCleaner: Clean & Copy"
      },
      {
        "command": "code-cleaner.aiCleanCode",
        "title": "CodeCleaner: AI Refactor"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "code-cleaner.cleanCode",
          "group": "modification"
        },
        {
          "command": "code-cleaner.cleanAndCopy",
          "group": "modification"
        },
        {
          "command": "code-cleaner.aiCleanCode",
          "group": "modification"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "npm run esbuild-base",
    "watch": "npm run esbuild-base -- --watch",
    "package": "npm run esbuild-base -- --minify",
    "esbuild-base": "node esbuild.js",
    "pretest": "npm run compile",
    "lint": "eslint src --ext ts",
    "test": "npm run compile && node ./out/test/runTest.js"
  },
  "devDependencies": {
    "@types/emscripten": "^1.41.5",
    "@types/node": "18.x",
    "@types/vscode": "^1.80.0",
    "@vscode/test-electron": "^2.3.8",
    "@types/mocha": "^10.0.6",
    "@types/chai": "^4.3.11",
    "chai": "^4.4.1",
    "mocha": "^10.2.0",
    "glob": "^8.1.0",
    "esbuild": "^0.19.11",
    "typescript": "^5.1.3"
  },
  "dependencies": {
    "tree-sitter-wasms": "^0.1.13",
    "web-tree-sitter": "^0.20.8",
    "terser": "^5.27.0",
    "@google/genai": "latest",
    "openai": "^4.24.1"
  }
}